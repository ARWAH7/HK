{
  "manifest_version": 3,
  "name": "哈希游戏下注执行器 v2 (WS触发)",
  "version": "2.0.0",
  "description": "WS触发极速投注 - 上一区块结果到达时立即下注，目标执行时间≤80ms",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://*.amazonaws.com/*",
    "http://*.amazonaws.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.amazonaws.com/*",
        "http://*.amazonaws.com/*",
        "http://localhost:*/*",
        "https://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "HAXI v2执行器"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
